# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=harness_db
POSTGRES_USER=harness
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# MCP Server
MCP_SERVER_URL=http://localhost:8001

# Budget limits per session
SESSION_BUDGET_TOKENS=50000
SESSION_BUDGET_CALLS=100

# Harness
HARNESS_HOST=0.0.0.0
HARNESS_PORT=8000
METRICS_PORT=8080
LOG_LEVEL=INFO

# Human-in-the-loop
HITL_APPROVAL_TIMEOUT_SECONDS=30
HITL_WEBHOOK_URL=

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# File read tool — allowed base directory
FILE_READ_BASE_DIR=/tmp/agent_files
